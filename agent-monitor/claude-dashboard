#!/bin/bash
# Claude Code Agent Dashboard — interactive TUI for monitoring Claude agents
# across tmux sessions. Agent state detected via hooks (claude-state-hook).
# Compatible with macOS bash 3.2. Flicker-free. Vim-navigable.
# Sessions as side-by-side columns, agents stacked vertically within each.

REFRESH_INTERVAL=5
STATE_DIR="/tmp/claude-agent-states"
DATA_DIR="$HOME/.local/share/agent-monitor"
TRACKER_FILE="$DATA_DIR/tracker.md"
mkdir -p "$DATA_DIR"
[ -f "$TRACKER_FILE" ] || printf '# Agent Tracker\n\n' > "$TRACKER_FILE"
MIN_COL_W=30

# Colors & escapes
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'
GREEN='\033[32m'
YELLOW='\033[33m'
CYAN='\033[36m'
WHITE='\033[37m'
BG_BLUE='\033[44m'
EL='\033[K'
CUR_HOME='\033[H'
ERASE_DOWN='\033[J'

# Pre-expand ANSI codes for safe %s usage in render
X_BG_SEL=$(printf '\033[48;5;237m')
X_RESET=$(printf '\033[0m')
X_BOLD=$(printf '\033[1m')
X_DIM=$(printf '\033[2m')
X_GREEN=$(printf '\033[32m')
X_YELLOW=$(printf '\033[33m')
X_CYAN=$(printf '\033[36m')
X_ORANGE=$(printf '\033[38;5;208m')
X_RED=$(printf '\033[31m')
X_MAGENTA=$(printf '\033[35m')
X_BG_MARK=$(printf '\033[48;5;53m')
X_BG_MARK_DIM=$(printf '\033[48;5;54m')

SPINNER=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
SPIN_IDX=0

# Global state
AGENT_COUNT=0
SELECTED=1
FIRST_DRAW=1

# Per-agent raw data (0-indexed)
A_STATE=()
A_WINPANE=()
A_UPTIME=()
C_SESSIONS=()
AGENT_PANE_IDS=()
AGENT_SESSIONS=()
C_THINKING=0
C_WAITING=0
C_IDLE=0
A_WIN=()
A_TTY=()
A_STATE_SECS=()

# Activity feed & transition tracking
EVENT_LOG=()
PREV_A_TTY=()
PREV_A_STATE=()
PREV_A_MTIME=()

# Per-app
APP_COUNT=0
APP_SESSION=()
APP_WIN=()
APP_CMD=()

# Render items (flat sequence, per-session offsets)
RENDER_TYPE=()         # "h"=window header, "a"=agent, "p"=app
RENDER_IDX=()          # agent/app index (for "a"/"p"), window name (for "h")
RENDER_SESS_START=()   # offset into RENDER_* for each session
RENDER_SESS_COUNT=()   # line count per session

# Session boundaries (populated by fetch_agents)
SESS_NAMES=()    # unique session names
SESS_START=()    # global index of first agent in each session
SESS_COUNT=()    # agent count per session
SESS_THINKING=()
SESS_WAITING=()
SESS_IDLE=()

# State file lookup (bash 3.2 compatible, no associative arrays)
STATE_TTYS=()
STATE_VALS=()
STATE_MTIMES=()

load_agent_states() {
  STATE_TTYS=()
  STATE_VALS=()
  STATE_MTIMES=()
  [ -d "$STATE_DIR" ] || return
  for sf in "$STATE_DIR"/*; do
    [ -f "$sf" ] || continue
    local s_state="" s_tty=""
    { read -r s_state; read -r s_tty; } < "$sf"
    if [ -n "$s_tty" ] && [ -n "$s_state" ]; then
      STATE_TTYS+=("$s_tty")
      STATE_VALS+=("$s_state")
      local s_mtime
      s_mtime=$(stat -f %m "$sf" 2>/dev/null) || s_mtime=0
      STATE_MTIMES+=("$s_mtime")
    fi
  done
}

get_agent_state() {
  local tty="$1" i=0
  while [ "$i" -lt "${#STATE_TTYS[@]}" ]; do
    if [ "${STATE_TTYS[$i]}" = "$tty" ]; then
      printf '%s' "${STATE_VALS[$i]}"
      return
    fi
    i=$((i + 1))
  done
  printf 'unknown'
}

get_state_mtime() {
  local tty="$1" i=0
  while [ "$i" -lt "${#STATE_TTYS[@]}" ]; do
    if [ "${STATE_TTYS[$i]}" = "$tty" ]; then
      printf '%s' "${STATE_MTIMES[$i]}"
      return
    fi
    i=$((i + 1))
  done
  printf '0'
}

parse_elapsed() {
  local etime="$1"
  local days=0 hours=0 mins=0 secs=0
  if [[ "$etime" == *-* ]]; then
    days="${etime%%-*}"; etime="${etime#*-}"
  fi
  IFS=: read -ra parts <<< "$etime"
  local n=${#parts[@]}
  if [ "$n" -eq 3 ]; then
    hours="${parts[0]}"; mins="${parts[1]}"; secs="${parts[2]}"
  elif [ "$n" -eq 2 ]; then
    mins="${parts[0]}"; secs="${parts[1]}"
  fi
  days=$((10#$days)); hours=$((10#$hours)); mins=$((10#$mins)); secs=$((10#$secs))
  if [ "$days" -gt 0 ]; then echo "${days}d ${hours}h"
  elif [ "$hours" -gt 0 ]; then echo "${hours}h ${mins}m"
  elif [ "$mins" -gt 0 ]; then echo "${mins}m"
  else echo "${secs}s"; fi
}

format_seconds() {
  local s=$1
  if [ "$s" -ge 86400 ]; then
    echo "$((s / 86400))d $((s % 86400 / 3600))h"
  elif [ "$s" -ge 3600 ]; then
    echo "$((s / 3600))h $((s % 3600 / 60))m"
  elif [ "$s" -ge 60 ]; then
    echo "$((s / 60))m"
  else
    echo "${s}s"
  fi
}

fetch_agents() {
  AGENT_COUNT=0
  A_STATE=(); A_WINPANE=(); A_UPTIME=(); A_WIN=(); A_TTY=(); A_STATE_SECS=()
  C_SESSIONS=(); AGENT_PANE_IDS=(); AGENT_SESSIONS=()
  C_THINKING=0; C_WAITING=0; C_IDLE=0
  SESS_NAMES=(); SESS_START=(); SESS_COUNT=()
  SESS_THINKING=(); SESS_WAITING=(); SESS_IDLE=()
  APP_COUNT=0; APP_SESSION=(); APP_WIN=(); APP_CMD=()

  # Single ps call for both agents and apps
  local ps_all
  ps_all=$(ps -eo tty=,pid=,pcpu=,etime=,comm= 2>/dev/null || true)
  local ps_agents
  ps_agents=$(printf '%s\n' "$ps_all" | grep -E ' claude$' | grep -v grep || true)
  [ -z "$ps_agents" ] && return

  local ps_apps
  ps_apps=$(ps -eo tty=,args= 2>/dev/null | grep 'pnpm' | grep ' dev' | grep -v grep || true)

  # Build TTY lookup via awk in one pass (avoids per-agent bash loops)
  local tmux_raw
  tmux_raw=$(tmux list-panes -a -F '#{pane_tty}|#{session_name}|#{window_name}|#{pane_index}|#{pane_id}' 2>/dev/null || true)

  # Pre-build lookup arrays: TMUX_LOOKUP_* indexed by tty (via awk output)
  # Output format: tty|session|win:pane_idx|pane_id|win
  local lookup_data
  lookup_data=$(printf '%s\n' "$tmux_raw" | awk -F'|' '{
    tty = $1; sub(/^\/dev\//, "", tty)
    print tty "|" $2 "|" $3 ":" $4 "|" $5 "|" $3
  }')

  # Store lookup as arrays for fast access
  TMUX_L_TTY=(); TMUX_L_SESS=(); TMUX_L_WINPANE=(); TMUX_L_PANEID=(); TMUX_L_WIN=()
  while IFS='|' read -r _lt _ls _lwp _lp _lw; do
    TMUX_L_TTY+=("$_lt")
    TMUX_L_SESS+=("$_ls")
    TMUX_L_WINPANE+=("$_lwp")
    TMUX_L_PANEID+=("$_lp")
    TMUX_L_WIN+=("$_lw")
  done <<< "$lookup_data"
  local tmux_count=${#TMUX_L_TTY[@]}

  load_agent_states

  # Join agents with tmux data via awk instead of per-agent lookup_tty calls
  local joined
  joined=$(awk -F'|' '
    NR == FNR { sess[$1]=$2; wp[$1]=$3":"$4; pid5[$1]=$5; next }
    {
      split($0, f, " ")
      tty = f[1]; sub(/^\/dev\//, "", tty)
      if (tty in sess)
        print sess[tty] "|" wp[tty] "|" f[2] "|" f[3] "|" f[4] "|" pid5[tty] "|" tty
    }
  ' <(printf '%s\n' "$tmux_raw" | sed 's|^/dev/||') <(printf '%s\n' "$ps_agents") \
    | sort -t'|' -k1,1 -k2,2)

  [ -z "$joined" ] && return

  local now_epoch
  now_epoch=$(date +%s)

  while IFS='|' read -r session winpane pid cpu etime pane_id tty; do
    [ -z "$session" ] && session="unknown"
    [ -z "$winpane" ] && winpane="?"

    AGENT_PANE_IDS+=("$pane_id")
    AGENT_SESSIONS+=("$session")
    C_SESSIONS+=("$session")

    local agent_state
    agent_state=$(get_agent_state "$tty")

    A_STATE+=("$agent_state")
    A_WINPANE+=("$winpane")
    A_TTY+=("$tty")
    A_WIN+=("${winpane%%:*}")

    # Time-in-current-state from state file mtime; fall back to process uptime
    local state_mtime secs_in_state=0
    state_mtime=$(get_state_mtime "$tty")
    if [ "$state_mtime" -gt 0 ]; then
      secs_in_state=$((now_epoch - state_mtime))
      [ "$secs_in_state" -lt 0 ] && secs_in_state=0
      A_UPTIME+=("$(format_seconds "$secs_in_state")")
    else
      A_UPTIME+=("$(parse_elapsed "$etime")")
    fi
    A_STATE_SECS+=("$secs_in_state")

    case "$agent_state" in
      thinking) C_THINKING=$((C_THINKING + 1)) ;;
      waiting)  C_WAITING=$((C_WAITING + 1)) ;;
      *)        C_IDLE=$((C_IDLE + 1)) ;;
    esac

    AGENT_COUNT=$((AGENT_COUNT + 1))
  done <<< "$joined"

  # Build session boundary lookup
  local prev="" i=0
  while [ "$i" -lt "$AGENT_COUNT" ]; do
    local s="${C_SESSIONS[$i]}"
    if [ "$s" != "$prev" ]; then
      SESS_NAMES+=("$s")
      SESS_START+=("$i")
      SESS_COUNT+=(0)
      SESS_THINKING+=(0)
      SESS_WAITING+=(0)
      SESS_IDLE+=(0)
      prev="$s"
    fi
    local si=$(( ${#SESS_COUNT[@]} - 1 ))
    SESS_COUNT[$si]=$(( ${SESS_COUNT[$si]} + 1 ))
    case "${A_STATE[$i]}" in
      thinking) SESS_THINKING[$si]=$(( ${SESS_THINKING[$si]} + 1 )) ;;
      waiting)  SESS_WAITING[$si]=$(( ${SESS_WAITING[$si]} + 1 )) ;;
      *)        SESS_IDLE[$si]=$(( ${SESS_IDLE[$si]} + 1 )) ;;
    esac
    i=$((i + 1))
  done

  if [ "$SELECTED" -gt "$AGENT_COUNT" ]; then SELECTED=$AGENT_COUNT; fi
  if [ "$SELECTED" -lt 1 ] && [ "$AGENT_COUNT" -gt 0 ]; then SELECTED=1; fi

  # Detect apps (pnpm dev) — only in sessions that have agents
  if [ -n "$ps_apps" ]; then
    # Join apps with tmux data via awk
    local app_joined
    app_joined=$(awk -F'|' '
      NR == FNR { sess[$1]=$2; win[$1]=$3; next }
      {
        split($0, f, " ")
        tty = f[1]; sub(/^\/dev\//, "", tty)
        if (tty in sess && !seen[tty]++) print sess[tty] "|" win[tty]
      }
    ' <(printf '%s\n' "$tmux_raw" | sed 's|^/dev/||' | awk -F'|' '{print $1 "|" $2 "|" $3}') \
      <(printf '%s\n' "$ps_apps"))

    while IFS='|' read -r asess awin; do
      [ -z "$asess" ] && continue
      # Only include apps in sessions that have agents
      local found=0 asi=0
      while [ "$asi" -lt "${#SESS_NAMES[@]}" ]; do
        [ "${SESS_NAMES[$asi]}" = "$asess" ] && { found=1; break; }
        asi=$((asi + 1))
      done
      [ "$found" -eq 0 ] && continue

      APP_SESSION+=("$asess")
      APP_WIN+=("${awin:-?}")
      APP_CMD+=("pnpm dev")
      APP_COUNT=$((APP_COUNT + 1))
    done <<< "$app_joined"
  fi
}

build_render_items() {
  RENDER_TYPE=(); RENDER_IDX=()
  RENDER_SESS_START=(); RENDER_SESS_COUNT=()

  local si=0
  while [ "$si" -lt "${#SESS_NAMES[@]}" ]; do
    local sname="${SESS_NAMES[$si]}"
    local s_start="${SESS_START[$si]}"
    local s_count="${SESS_COUNT[$si]}"
    local s_end=$((s_start + s_count))

    RENDER_SESS_START+=("${#RENDER_TYPE[@]}")
    local lines=0

    # Collect unique window names for agents in this session (preserving order)
    local win_names=()
    local ai="$s_start"
    while [ "$ai" -lt "$s_end" ]; do
      local wn="${A_WIN[$ai]}"
      local dup=0 dwi=0
      while [ "$dwi" -lt "${#win_names[@]}" ]; do
        [ "${win_names[$dwi]}" = "$wn" ] && { dup=1; break; }
        dwi=$((dwi + 1))
      done
      [ "$dup" -eq 0 ] && win_names+=("$wn")
      ai=$((ai + 1))
    done

    # For each agent window: header + agents + matching apps
    local wwi=0
    while [ "$wwi" -lt "${#win_names[@]}" ]; do
      local wn="${win_names[$wwi]}"

      RENDER_TYPE+=("h")
      RENDER_IDX+=("$wn")
      lines=$((lines + 1))

      ai="$s_start"
      while [ "$ai" -lt "$s_end" ]; do
        if [ "${A_WIN[$ai]}" = "$wn" ]; then
          RENDER_TYPE+=("a")
          RENDER_IDX+=("$ai")
          lines=$((lines + 1))
        fi
        ai=$((ai + 1))
      done

      local pi=0
      while [ "$pi" -lt "$APP_COUNT" ]; do
        if [ "${APP_SESSION[$pi]}" = "$sname" ] && [ "${APP_WIN[$pi]}" = "$wn" ]; then
          RENDER_TYPE+=("p")
          RENDER_IDX+=("$pi")
          lines=$((lines + 1))
        fi
        pi=$((pi + 1))
      done

      wwi=$((wwi + 1))
    done

    # Second pass: app-only windows in this session
    local app_only_wins=()
    local pi=0
    while [ "$pi" -lt "$APP_COUNT" ]; do
      if [ "${APP_SESSION[$pi]}" = "$sname" ]; then
        local awname="${APP_WIN[$pi]}"
        local has_agents=0 awi=0
        while [ "$awi" -lt "${#win_names[@]}" ]; do
          [ "${win_names[$awi]}" = "$awname" ] && { has_agents=1; break; }
          awi=$((awi + 1))
        done
        if [ "$has_agents" -eq 0 ]; then
          local adup=0 aoi=0
          while [ "$aoi" -lt "${#app_only_wins[@]}" ]; do
            [ "${app_only_wins[$aoi]}" = "$awname" ] && { adup=1; break; }
            aoi=$((aoi + 1))
          done
          [ "$adup" -eq 0 ] && app_only_wins+=("$awname")
        fi
      fi
      pi=$((pi + 1))
    done

    local aowi=0
    while [ "$aowi" -lt "${#app_only_wins[@]}" ]; do
      local awname="${app_only_wins[$aowi]}"
      RENDER_TYPE+=("h")
      RENDER_IDX+=("$awname")
      lines=$((lines + 1))

      pi=0
      while [ "$pi" -lt "$APP_COUNT" ]; do
        if [ "${APP_SESSION[$pi]}" = "$sname" ] && [ "${APP_WIN[$pi]}" = "$awname" ]; then
          RENDER_TYPE+=("p")
          RENDER_IDX+=("$pi")
          lines=$((lines + 1))
        fi
        pi=$((pi + 1))
      done

      aowi=$((aowi + 1))
    done

    RENDER_SESS_COUNT+=("$lines")
    si=$((si + 1))
  done
}

PREV_STATE_FILE="/tmp/claude-dashboard-prev-states"
EVENT_LOG_FILE="/tmp/claude-dashboard-event-log"
NOTIF_FILE="/tmp/claude-dashboard-notifs"
SELECTED_FILE="/tmp/claude-dashboard-selected"
NOTIF_TTYS=()

MARK_FILE="/tmp/claude-dashboard-marks"
MARK_TTYS=()

load_notifications() {
  NOTIF_TTYS=()
  [ -f "$NOTIF_FILE" ] || return
  while IFS= read -r ntty; do
    [ -n "$ntty" ] && NOTIF_TTYS+=("$ntty")
  done < "$NOTIF_FILE"
}

save_notifications() {
  : > "$NOTIF_FILE"
  local i=0
  while [ "$i" -lt "${#NOTIF_TTYS[@]}" ]; do
    printf '%s\n' "${NOTIF_TTYS[$i]}" >> "$NOTIF_FILE"
    i=$((i + 1))
  done
}

has_notification() {
  local tty="$1" i=0
  while [ "$i" -lt "${#NOTIF_TTYS[@]}" ]; do
    [ "${NOTIF_TTYS[$i]}" = "$tty" ] && return 0
    i=$((i + 1))
  done
  return 1
}

add_notification() {
  local tty="$1"
  has_notification "$tty" && return
  NOTIF_TTYS+=("$tty")
  save_notifications
}

remove_notification() {
  local tty="$1"
  has_notification "$tty" || return
  local new_list=() i=0
  while [ "$i" -lt "${#NOTIF_TTYS[@]}" ]; do
    [ "${NOTIF_TTYS[$i]}" != "$tty" ] && new_list+=("${NOTIF_TTYS[$i]}")
    i=$((i + 1))
  done
  NOTIF_TTYS=("${new_list[@]}")
  save_notifications
}

load_marks() {
  MARK_TTYS=()
  [ -f "$MARK_FILE" ] || return
  while IFS= read -r mtty; do
    [ -n "$mtty" ] && MARK_TTYS+=("$mtty")
  done < "$MARK_FILE"
}

save_marks() {
  : > "$MARK_FILE"
  local i=0
  while [ "$i" -lt "${#MARK_TTYS[@]}" ]; do
    printf '%s\n' "${MARK_TTYS[$i]}" >> "$MARK_FILE"
    i=$((i + 1))
  done
}

has_mark() {
  local tty="$1" i=0
  while [ "$i" -lt "${#MARK_TTYS[@]}" ]; do
    [ "${MARK_TTYS[$i]}" = "$tty" ] && return 0
    i=$((i + 1))
  done
  return 1
}

toggle_mark() {
  local tty="$1"
  if has_mark "$tty"; then
    local new_list=() i=0
    while [ "$i" -lt "${#MARK_TTYS[@]}" ]; do
      [ "${MARK_TTYS[$i]}" != "$tty" ] && new_list+=("${MARK_TTYS[$i]}")
      i=$((i + 1))
    done
    MARK_TTYS=("${new_list[@]}")
  else
    MARK_TTYS+=("$tty")
  fi
  save_marks
}

load_event_log() {
  EVENT_LOG=()
  [ -f "$EVENT_LOG_FILE" ] || return
  while IFS= read -r eline; do
    [ -n "$eline" ] || continue
    EVENT_LOG+=("$eline")
  done < "$EVENT_LOG_FILE"
}

save_event_log() {
  : > "$EVENT_LOG_FILE"
  local i=0
  while [ "$i" -lt "${#EVENT_LOG[@]}" ]; do
    printf '%s\n' "${EVENT_LOG[$i]}" >> "$EVENT_LOG_FILE"
    i=$((i + 1))
  done
}

detect_transitions() {
  # Load previous states from file on first run (format: tty|state|mtime)
  if [ "${#PREV_A_TTY[@]}" -eq 0 ] && [ -f "$PREV_STATE_FILE" ]; then
    while IFS='|' read -r ptty pstate pmtime; do
      [ -n "$ptty" ] || continue
      PREV_A_TTY+=("$ptty")
      PREV_A_STATE+=("$pstate")
      PREV_A_MTIME+=("${pmtime:-0}")
    done < "$PREV_STATE_FILE"
  fi

  # Load event log from file on first run
  if [ "${#EVENT_LOG[@]}" -eq 0 ]; then
    load_event_log
  fi

  local now_time
  now_time=$(date +%H:%M:%S)
  local bell=0 changed=0
  local i=0
  while [ "$i" -lt "$AGENT_COUNT" ]; do
    local tty="${A_TTY[$i]}"
    local new_state="${A_STATE[$i]}"
    local new_mtime
    new_mtime=$(get_state_mtime "$tty")
    # Find previous state for this TTY
    local prev_state="" prev_mtime="0" pi=0
    while [ "$pi" -lt "${#PREV_A_TTY[@]}" ]; do
      if [ "${PREV_A_TTY[$pi]}" = "$tty" ]; then
        prev_state="${PREV_A_STATE[$pi]}"
        prev_mtime="${PREV_A_MTIME[$pi]:-0}"
        break
      fi
      pi=$((pi + 1))
    done
    if [ -n "$prev_state" ]; then
      local sess="${AGENT_SESSIONS[$i]}"
      local win="${A_WIN[$i]}"
      if [ "$prev_state" != "$new_state" ]; then
        EVENT_LOG+=("${now_time} ${sess}/${win}: ${prev_state} → ${new_state}")
        changed=1
        [ "$new_state" = "waiting" ] && bell=1
        [ "$new_state" = "idle" ] && add_notification "$tty"
        [ "$prev_state" = "idle" ] && remove_notification "$tty"
      elif [ "$new_mtime" != "$prev_mtime" ] && [ "$new_mtime" != "0" ]; then
        # Same state but mtime changed — agent cycled while away
        EVENT_LOG+=("${now_time} ${sess}/${win}: ↻ ${new_state} (updated)")
        changed=1
      fi
      while [ "${#EVENT_LOG[@]}" -gt 8 ]; do
        EVENT_LOG=("${EVENT_LOG[@]:1}")
      done
    fi
    i=$((i + 1))
  done
  PREV_A_TTY=("${A_TTY[@]}")
  PREV_A_STATE=("${A_STATE[@]}")
  PREV_A_MTIME=()

  # Persist current states for next dashboard session (format: tty|state|mtime)
  : > "$PREV_STATE_FILE"
  i=0
  while [ "$i" -lt "$AGENT_COUNT" ]; do
    local mt
    mt=$(get_state_mtime "${A_TTY[$i]}")
    PREV_A_MTIME+=("$mt")
    printf '%s|%s|%s\n' "${A_TTY[$i]}" "${A_STATE[$i]}" "$mt" >> "$PREV_STATE_FILE"
    i=$((i + 1))
  done

  # Persist event log if changed
  [ "$changed" -eq 1 ] && save_event_log

  [ "$bell" -eq 1 ] && printf '\a'
}

# Clear notifications for agents whose pane is currently visible in tmux
clear_seen_notifications() {
  [ "${#NOTIF_TTYS[@]}" -eq 0 ] && return
  local vis_output
  vis_output=$(tmux list-panes -a -F '#{pane_tty}|#{pane_active}|#{window_active}' 2>/dev/null || true)
  [ -z "$vis_output" ] && return
  while IFS='|' read -r vtty vactive wactive; do
    vtty="${vtty#/dev/}"
    if [ "$vactive" = "1" ] && [ "$wactive" = "1" ]; then
      remove_notification "$vtty"
    fi
  done <<< "$vis_output"
}

# Print 1-line agent card:  [SR] ● THINKING         5m
# Args: agent_idx card_width is_highlighted row_label
print_agent_line() {
  local idx=$1 cw=$2 hl=$3 row_label=$4
  local state="${A_STATE[$idx]}"
  local up="${A_UPTIME[$idx]}"

  local secs="${A_STATE_SECS[$idx]}"
  local ic label color
  case "$state" in
    thinking) ic="●"; label="THINKING"; color="$X_GREEN" ;;
    waiting)
      ic="◆"; label="WAITING"
      if [ "$secs" -gt 600 ]; then
        color="$X_RED"
      elif [ "$secs" -gt 300 ]; then
        color="$X_ORANGE"
      else
        color="$X_YELLOW"
      fi
      ;;
    idle)
      if has_notification "${A_TTY[$idx]}"; then
        ic="✓"; label="DONE"
        if [ "$secs" -gt 600 ]; then
          color="$X_RED"
        elif [ "$secs" -gt 300 ]; then
          color="$X_ORANGE"
        elif [ "$secs" -gt 120 ]; then
          color="$X_YELLOW"
        else
          color="$X_MAGENTA"
        fi
      else
        ic="○"; label="IDLE"; color="$X_DIM"
      fi
      ;;
    *)        ic="?"; label="UNKNOWN";  color="$X_DIM" ;;
  esac

  local marked=0
  has_mark "${A_TTY[$idx]}" && marked=1

  local mark_prefix=""
  [ "$marked" -eq 1 ] && mark_prefix="★ "

  local left_len=$(( 2 + ${#row_label} + 1 + ${#mark_prefix} + 1 + 1 + ${#label} ))
  local gap=$(( cw - left_len - ${#up} ))
  [ "$gap" -lt 1 ] && gap=1

  local bg_on="" RST="$X_RESET"
  if [ "$hl" -eq 1 ] && [ "$marked" -eq 1 ]; then
    bg_on="$X_BG_MARK"; RST="${X_RESET}${X_BG_MARK}"
  elif [ "$hl" -eq 1 ]; then
    bg_on="$X_BG_SEL"; RST="${X_RESET}${X_BG_SEL}"
  elif [ "$marked" -eq 1 ]; then
    bg_on="$X_BG_MARK_DIM"; RST="${X_RESET}${X_BG_MARK_DIM}"
  fi

  local mark_display=""
  if [ "$marked" -eq 1 ]; then
    mark_display="${X_YELLOW}${X_BOLD}★${RST} "
  fi

  printf '%s  %s %s%s%s%s %s%s%s%s%*s%s%s%s' \
    "$bg_on" \
    "$row_label" \
    "$mark_display" \
    "$color" "$ic" "$RST" \
    "$color" "$X_BOLD" "$label" "$RST" \
    "$gap" "" \
    "$color" "$up" "$X_RESET"
}

# Print window header: ▸ window-name
# Args: window_name card_width
print_window_header() {
  local wname="$1" cw=$2
  local hdr="▸ ${wname}"
  local hdr_len=${#hdr}
  local pad=$((cw - hdr_len))
  [ "$pad" -lt 0 ] && pad=0
  printf '%s%s%s%s%*s' "$X_BOLD" "$X_CYAN" "$hdr" "$X_RESET" "$pad" ""
}

# Print app line:  ⚡ pnpm dev
# Args: app_idx card_width
print_app_line() {
  local idx=$1 cw=$2
  local cmd="${APP_CMD[$idx]}"
  local line="  ⚡ ${cmd}"
  local vlen=${#line}
  local pad=$((cw - vlen))
  [ "$pad" -lt 0 ] && pad=0
  printf '%s%s%s%*s' "$X_DIM" "$line" "$X_RESET" "$pad" ""
}

render() {
  if [ "$FIRST_DRAW" -eq 1 ]; then
    clear
    FIRST_DRAW=0
  else
    printf "${CUR_HOME}"
  fi

  local spin="${SPINNER[$SPIN_IDX]}"
  SPIN_IDX=$(( (SPIN_IDX + 1) % ${#SPINNER[@]} ))

  # Terminal width (stty is more reliable inside tmux popups)
  local tw
  tw=$(stty size 2>/dev/null | awk '{print $2}') || tw=80
  [ -z "$tw" ] || [ "$tw" -eq 0 ] 2>/dev/null && tw=$(tput cols 2>/dev/null) || true
  [ -z "$tw" ] || [ "$tw" -eq 0 ] 2>/dev/null && tw=80

  printf "${EL}\n"
  printf "  ${BOLD}\033[7m  Agent Dashboard  ${RESET}${EL}\n"
  printf "${EL}\n"

  if [ "$AGENT_COUNT" -eq 0 ]; then
    printf "  ${DIM}No Claude Code agents detected.${RESET}${EL}\n"
    printf "${EL}\n"
    printf "  ${DIM}Start a Claude session in a tmux pane to see it here.${RESET}${EL}\n"
    printf "${EL}\n"
    printf "  ${BOLD}[r]${RESET} Refresh  ${BOLD}[q]${RESET} Quit${EL}\n"
    printf "  ${DIM}${spin} Auto-refresh every ${REFRESH_INTERVAL}s | $(date +%H:%M:%S)${RESET}${EL}\n"
    printf "${ERASE_DOWN}"
    return
  fi

  local total_sessions=${#SESS_NAMES[@]}

  # Compute max columns that fit at MIN_COL_W
  local max_cols=$(( (tw - 2) / MIN_COL_W ))
  [ "$max_cols" -lt 1 ] && max_cols=1

  # Render session columns in groups of max_cols
  local group=0
  while [ "$group" -lt "$total_sessions" ]; do
    local remaining=$((total_sessions - group))
    local ncols=$remaining
    [ "$ncols" -gt "$max_cols" ] && ncols=$max_cols

    local group_end=$((group + ncols))

    # Column width: divide terminal evenly across session columns
    local cw=$(( (tw - 2) / ncols ))

    # Find max render lines in this group of sessions
    local max_lines=0 c=$group
    while [ "$c" -lt "$group_end" ]; do
      local cnt="${RENDER_SESS_COUNT[$c]}"
      [ "$cnt" -gt "$max_lines" ] && max_lines=$cnt
      c=$((c + 1))
    done

    # Session header row with productivity bar
    c=$group
    while [ "$c" -lt "$group_end" ]; do
      local snum=$((c + 1))
      local sname="${SESS_NAMES[$c]}"
      local st="${SESS_THINKING[$c]}"
      local sw="${SESS_WAITING[$c]}"
      local sid="${SESS_IDLE[$c]}"
      if [ "$c" -eq "$group" ]; then
        printf '  '
      fi

      # Compute suffix length: bar + space + counts
      local suffix_len=$((st + sw + sid + 1))
      [ "$st" -gt 0 ] && suffix_len=$((suffix_len + ${#st} + 1))
      [ "$sw" -gt 0 ] && suffix_len=$((suffix_len + ${#sw} + 1))
      [ "$sid" -gt 0 ] && suffix_len=$((suffix_len + ${#sid} + 1))

      # Truncate session name if it would overflow the column
      local fixed_len=$(( 2 + ${#snum} + 1 + 2 ))  # "┌ N " + "  " gap
      local max_name=$(( cw - fixed_len - suffix_len ))
      [ "$max_name" -lt 3 ] && max_name=3
      local dname="$sname"
      if [ "${#dname}" -gt "$max_name" ]; then
        dname="${dname:0:$((max_name - 1))}…"
      fi

      local prefix="┌ ${snum} ${dname}  "
      printf "${BOLD}%s${RESET}" "$prefix"
      local vlen=${#prefix}

      # Productivity bar: green ▓ per thinking, yellow ▓ per waiting, dim ░ per idle
      local _bi=0
      while [ "$_bi" -lt "$st" ]; do printf "${GREEN}▓"; _bi=$((_bi+1)); done
      _bi=0
      while [ "$_bi" -lt "$sw" ]; do printf "${YELLOW}▓"; _bi=$((_bi+1)); done
      _bi=0
      while [ "$_bi" -lt "$sid" ]; do printf '\033[2m░'; _bi=$((_bi+1)); done
      printf "${RESET} "
      vlen=$((vlen + st + sw + sid + 1))

      # State counts: 2●1◆1○
      if [ "$st" -gt 0 ]; then printf "${GREEN}${st}●${RESET}"; vlen=$((vlen + ${#st} + 1)); fi
      if [ "$sw" -gt 0 ]; then printf "${YELLOW}${sw}◆${RESET}"; vlen=$((vlen + ${#sw} + 1)); fi
      if [ "$sid" -gt 0 ]; then printf '\033[2m'"${sid}○${RESET}"; vlen=$((vlen + ${#sid} + 1)); fi

      local hdr_pad=$((cw - vlen))
      [ "$hdr_pad" -lt 0 ] && hdr_pad=0
      printf "%*s" "$hdr_pad" ""
      c=$((c + 1))
    done
    printf "${EL}\n"

    # Render lines — one terminal line per render item
    local line=0
    while [ "$line" -lt "$max_lines" ]; do
      c=$group
      while [ "$c" -lt "$group_end" ]; do
        local r_start="${RENDER_SESS_START[$c]}"
        local r_count="${RENDER_SESS_COUNT[$c]}"

        if [ "$c" -eq "$group" ]; then
          printf '  '
        fi

        if [ "$line" -lt "$r_count" ]; then
          local ri=$((r_start + line))
          local rtype="${RENDER_TYPE[$ri]}"
          local ridx="${RENDER_IDX[$ri]}"
          printf '│ '
          local inner_w=$((cw - 3))

          case "$rtype" in
            h)
              print_window_header "$ridx" "$inner_w"
              ;;
            a)
              local hl=0
              [ "$((ridx + 1))" -eq "$SELECTED" ] && hl=1
              local snum=$((c + 1))
              local agent_row=0 scan="${RENDER_SESS_START[$c]}"
              while [ "$scan" -lt "$ri" ]; do
                [ "${RENDER_TYPE[$scan]}" = "a" ] && agent_row=$((agent_row + 1))
                scan=$((scan + 1))
              done
              local row_label="[${snum}$((agent_row + 1))]"
              print_agent_line "$ridx" "$inner_w" "$hl" "$row_label"
              ;;
            p)
              print_app_line "$ridx" "$inner_w"
              ;;
          esac
          printf ' '
        else
          printf '%*s' "$cw" ""
        fi
        c=$((c + 1))
      done
      printf "${EL}\n"

      line=$((line + 1))
    done

    # Blank separator between row groups of sessions
    [ "$group_end" -lt "$total_sessions" ] && printf "${EL}\n"

    group=$group_end
  done

  printf "${EL}\n"
  local summary_apps=""
  [ "$APP_COUNT" -gt 0 ] && summary_apps="  ${DIM}·  ${APP_COUNT} apps${RESET}"
  printf "  ${BOLD}Total:${RESET} ${AGENT_COUNT} agents  ${GREEN}${C_THINKING} thinking${RESET}  ${YELLOW}${C_WAITING} waiting${RESET}  ${DIM}${C_IDLE} idle${RESET}${summary_apps}${EL}\n"

  # Activity feed
  if [ "${#EVENT_LOG[@]}" -gt 0 ]; then
    printf "${EL}\n"
    local ei=0
    while [ "$ei" -lt "${#EVENT_LOG[@]}" ]; do
      printf "  ${DIM}▹ ${EVENT_LOG[$ei]}${RESET}${EL}\n"
      ei=$((ei + 1))
    done
  fi

  printf "${EL}\n"
  printf "  ${BOLD}h/j/k/l${RESET} Nav  ${BOLD}Enter${RESET} Jump  ${BOLD}[S][R]${RESET} Direct  ${BOLD}m${RESET} Mark  ${BOLD}s${RESET} Send  ${BOLD}t${RESET} Tracker  ${BOLD}r${RESET} Refresh  ${BOLD}q${RESET} Quit${EL}\n"
  printf "  ${DIM}${spin} Auto-refresh every ${REFRESH_INTERVAL}s | $(date +%H:%M:%S)${RESET}${EL}\n"
  printf "${ERASE_DOWN}"
}

jump_to_agent() {
  local num="$1"
  [ "$num" -lt 1 ] || [ "$num" -gt "$AGENT_COUNT" ] && return
  local idx=$((num - 1))
  SELECTED=$num
  remove_notification "${A_TTY[$idx]}"
  save_selected
  local pane_id="${AGENT_PANE_IDS[$idx]}"
  local session="${AGENT_SESSIONS[$idx]}"
  if [ -n "$pane_id" ] && [ -n "$session" ]; then
    printf 'switch-client -t "%s"\nselect-window -t "%s"\nselect-pane -t "%s"\n' \
      "$session" "$pane_id" "$pane_id" > /tmp/.claude-dashboard-jump
    exit 0
  fi
}

nav_down() {
  [ "$AGENT_COUNT" -eq 0 ] && return
  local idx=$((SELECTED - 1))
  local cur_sess="${C_SESSIONS[$idx]}"
  # Find end of current session
  local sess_end=$idx
  while [ "$sess_end" -lt $((AGENT_COUNT - 1)) ] && [ "${C_SESSIONS[$((sess_end + 1))]}" = "$cur_sess" ]; do
    sess_end=$((sess_end + 1))
  done
  if [ "$idx" -lt "$sess_end" ]; then
    SELECTED=$((idx + 2))
  else
    # Wrap to top of same session
    local sess_start=$idx
    while [ "$sess_start" -gt 0 ] && [ "${C_SESSIONS[$((sess_start - 1))]}" = "$cur_sess" ]; do
      sess_start=$((sess_start - 1))
    done
    SELECTED=$((sess_start + 1))
  fi
}

nav_up() {
  [ "$AGENT_COUNT" -eq 0 ] && return
  local idx=$((SELECTED - 1))
  local cur_sess="${C_SESSIONS[$idx]}"
  # Find start of current session
  local sess_start=$idx
  while [ "$sess_start" -gt 0 ] && [ "${C_SESSIONS[$((sess_start - 1))]}" = "$cur_sess" ]; do
    sess_start=$((sess_start - 1))
  done
  if [ "$idx" -gt "$sess_start" ]; then
    SELECTED=$idx
  else
    # Wrap to bottom of same session
    local sess_end=$idx
    while [ "$sess_end" -lt $((AGENT_COUNT - 1)) ] && [ "${C_SESSIONS[$((sess_end + 1))]}" = "$cur_sess" ]; do
      sess_end=$((sess_end + 1))
    done
    SELECTED=$((sess_end + 1))
  fi
}

nav_left() {
  [ "$AGENT_COUNT" -eq 0 ] && return
  local idx=$((SELECTED - 1))
  local cur_sess="${C_SESSIONS[$idx]}"
  # Find start of current session and current row
  local sess_start=$idx
  while [ "$sess_start" -gt 0 ] && [ "${C_SESSIONS[$((sess_start - 1))]}" = "$cur_sess" ]; do
    sess_start=$((sess_start - 1))
  done
  local row=$((idx - sess_start))
  # Find previous session
  if [ "$sess_start" -eq 0 ]; then
    # Wrap to last session
    local prev_end=$((AGENT_COUNT - 1))
  else
    local prev_end=$((sess_start - 1))
  fi
  local prev_sess="${C_SESSIONS[$prev_end]}"
  local prev_start=$prev_end
  while [ "$prev_start" -gt 0 ] && [ "${C_SESSIONS[$((prev_start - 1))]}" = "$prev_sess" ]; do
    prev_start=$((prev_start - 1))
  done
  local prev_count=$((prev_end - prev_start + 1))
  # Clamp row if target session is shorter
  [ "$row" -ge "$prev_count" ] && row=$((prev_count - 1))
  SELECTED=$((prev_start + row + 1))
}

nav_right() {
  [ "$AGENT_COUNT" -eq 0 ] && return
  local idx=$((SELECTED - 1))
  local cur_sess="${C_SESSIONS[$idx]}"
  # Find start/end of current session and current row
  local sess_start=$idx
  while [ "$sess_start" -gt 0 ] && [ "${C_SESSIONS[$((sess_start - 1))]}" = "$cur_sess" ]; do
    sess_start=$((sess_start - 1))
  done
  local sess_end=$idx
  while [ "$sess_end" -lt $((AGENT_COUNT - 1)) ] && [ "${C_SESSIONS[$((sess_end + 1))]}" = "$cur_sess" ]; do
    sess_end=$((sess_end + 1))
  done
  local row=$((idx - sess_start))
  # Find next session
  if [ "$sess_end" -ge $((AGENT_COUNT - 1)) ]; then
    # Wrap to first session
    local next_start=0
  else
    local next_start=$((sess_end + 1))
  fi
  local next_sess="${C_SESSIONS[$next_start]}"
  local next_end=$next_start
  while [ "$next_end" -lt $((AGENT_COUNT - 1)) ] && [ "${C_SESSIONS[$((next_end + 1))]}" = "$next_sess" ]; do
    next_end=$((next_end + 1))
  done
  local next_count=$((next_end - next_start + 1))
  # Clamp row if target session is shorter
  [ "$row" -ge "$next_count" ] && row=$((next_count - 1))
  SELECTED=$((next_start + row + 1))
}

send_to_agent() {
  local idx=$((SELECTED - 1))
  [ "$idx" -lt 0 ] || [ "$idx" -ge "$AGENT_COUNT" ] && return

  local pane_id="${AGENT_PANE_IDS[$idx]}"
  local session="${AGENT_SESSIONS[$idx]}"
  local win="${A_WIN[$idx]}"
  local state="${A_STATE[$idx]}"
  [ -z "$pane_id" ] && return

  # Capture pane, strip Claude UI chrome:
  # 1. Anchor on -- INSERT/NORMAL -- status bar (pure ASCII, reliable match)
  # 2. Hard-cut 3 lines above it (status bar + prompt area)
  # 3. Filter summary lines (duration pattern), separator lines (no alphanumeric)
  local preview
  preview=$(tmux capture-pane -p -t "$pane_id" 2>/dev/null \
    | awk '
      { lines[NR]=$0 }
      /-- (INSERT|NORMAL) --/ { bar=NR }
      END {
        e = (bar > 0) ? bar - 3 : NR
        if (e < 1) e = 1
        n = 0; last = 0
        for (i = 1; i <= e; i++) {
          if (lines[i] ~ / for [0-9]+[smhd]| Cost: /) continue
          if (lines[i] !~ /[A-Za-z0-9]/ && lines[i] !~ /^[[:space:]]*$/) continue
          buf[++n] = lines[i]
          if (lines[i] ~ /[^[:space:]]/) last = n
        }
        for (i = 1; i <= last; i++) print buf[i]
      }' \
    | tail -8)
  [ -z "$preview" ] && preview="(empty pane)"

  local tw
  tw=$(stty size 2>/dev/null | awk '{print $2}') || tw=80
  [ -z "$tw" ] || [ "$tw" -eq 0 ] 2>/dev/null && tw=80
  local dw=$((tw - 4))

  clear
  printf "\n"
  printf "  ${BOLD}Send to ${session}/${win}${RESET}  ${DIM}(${state})${RESET}\n"
  printf "  ${DIM}"; local _d=0; while [ "$_d" -lt "$dw" ]; do printf '─'; _d=$((_d+1)); done; printf "${RESET}\n"

  while IFS= read -r pline; do
    printf "  ${DIM}│${RESET} %s\n" "$pline"
  done <<< "$preview"

  printf "  ${DIM}"; _d=0; while [ "$_d" -lt "$dw" ]; do printf '─'; _d=$((_d+1)); done; printf "${RESET}\n"
  printf "\n"
  printf "  ${BOLD}>${RESET} "

  tput cnorm 2>/dev/null

  local input=""
  while true; do
    IFS= read -rsn1 ch
    local ch_ord=0
    if [ -n "$ch" ]; then
      ch_ord=$(printf '%d' "'$ch" 2>/dev/null) || ch_ord=0
    fi

    # Esc — cancel
    if [ "$ch_ord" -eq 27 ]; then
      tput civis 2>/dev/null
      FIRST_DRAW=1
      return
    fi

    # Enter — send if has non-space content
    if [ -z "$ch" ]; then
      if [ -n "${input// /}" ]; then
        tmux send-keys -t "$pane_id" -l "$input"
        tmux send-keys -t "$pane_id" Enter
        printf "\n\n  ${GREEN}${BOLD}✓ Sent${RESET}\n"
        sleep 0.5
      fi
      tput civis 2>/dev/null
      FIRST_DRAW=1
      return
    fi

    # Backspace
    if [ "$ch_ord" -eq 127 ] || [ "$ch_ord" -eq 8 ]; then
      if [ "${#input}" -gt 0 ]; then
        input="${input%?}"
        printf '\b \b'
      fi
      continue
    fi

    # Printable character
    if [ "$ch_ord" -ge 32 ]; then
      input="${input}${ch}"
      printf '%s' "$ch"
    fi
  done
}

save_selected() {
  [ "$AGENT_COUNT" -gt 0 ] && printf '%s\n' "${A_TTY[$((SELECTED - 1))]}" > "$SELECTED_FILE"
}

restore_selected() {
  [ -f "$SELECTED_FILE" ] || return
  local saved_tty
  read -r saved_tty < "$SELECTED_FILE"
  [ -z "$saved_tty" ] && return
  local i=0
  while [ "$i" -lt "$AGENT_COUNT" ]; do
    if [ "${A_TTY[$i]}" = "$saved_tty" ]; then
      SELECTED=$((i + 1))
      return
    fi
    i=$((i + 1))
  done
}

cleanup() {
  save_selected
  tput cnorm 2>/dev/null || true
}

main() {
  tput civis 2>/dev/null || true
  trap cleanup EXIT
  trap 'FIRST_DRAW=1' WINCH
  trap '' PIPE

  load_notifications
  load_marks
  fetch_agents
  restore_selected
  build_render_items
  detect_transitions
  clear_seen_notifications
  render

  local esc_state=0  # 0=normal, 1=got ESC, 2=got ESC+[
  while true; do
    key=""
    if [ "$esc_state" -gt 0 ]; then
      # Integer timeout for bash 3.2 compat; 1s is fine since we already got ESC
      read -rsn1 -t 1 key 2>/dev/null
      local rc=$?
      if [ $rc -ne 0 ] || [ -z "$key" ]; then
        esc_state=0
        render
        continue
      fi
    else
      read -rsn1 -t "$REFRESH_INTERVAL" key 2>/dev/null
      local rc=$?
      if [ $rc -ne 0 ]; then
        fetch_agents; build_render_items; detect_transitions; clear_seen_notifications; render
        continue
      fi
    fi

    if [ "$esc_state" -eq 0 ]; then
      local key_ord=0
      if [ -n "$key" ]; then
        key_ord=$(printf '%d' "'$key" 2>/dev/null) || key_ord=0
      fi
      if [ "$key_ord" -eq 27 ]; then
        esc_state=1
        continue
      fi
      case "$key" in
        q|Q) exit 0 ;;
        r|R) fetch_agents; build_render_items; detect_transitions; clear_seen_notifications; render ;;
        j) nav_down; render ;;
        k) nav_up; render ;;
        h) nav_left; render ;;
        l) nav_right; render ;;
        m) [ "$AGENT_COUNT" -gt 0 ] && toggle_mark "${A_TTY[$((SELECTED - 1))]}"; render ;;
        s) send_to_agent; fetch_agents; build_render_items; detect_transitions; clear_seen_notifications; render ;;
        t) tput cnorm 2>/dev/null; "${EDITOR:-vim}" "$TRACKER_FILE"; tput civis 2>/dev/null; FIRST_DRAW=1; render ;;
        G) [ "$AGENT_COUNT" -gt 0 ] && SELECTED=$AGENT_COUNT; render ;;
        g)
          g2=""
          read -rsn1 -t 1 g2 2>/dev/null || true
          [ "$g2" = "g" ] && [ "$AGENT_COUNT" -gt 0 ] && SELECTED=1
          render
          ;;
        "")
          if [ "$AGENT_COUNT" -gt 0 ]; then
            jump_to_agent "$SELECTED"
          fi
          ;;
        [1-9])
          d2=""
          read -rsn1 -t 1 d2 2>/dev/null || true
          case "$d2" in
            [1-9])
              # key=session number, d2=row number (both 1-indexed)
              local si=$((key - 1))
              local ri=$((d2 - 1))
              if [ "$si" -lt "${#SESS_START[@]}" ] && [ "$ri" -lt "${SESS_COUNT[$si]}" ]; then
                local target=$((SESS_START[si] + ri + 1))
                jump_to_agent "$target"
              fi
              ;;
          esac
          ;;
      esac
    elif [ "$esc_state" -eq 1 ]; then
      if [ "$key" = "[" ]; then
        esc_state=2
        continue
      fi
      esc_state=0
      render
    elif [ "$esc_state" -eq 2 ]; then
      esc_state=0
      case "$key" in
        A) nav_up; render ;;
        B) nav_down; render ;;
        C) nav_right; render ;;
        D) nav_left; render ;;
        *) render ;;
      esac
    fi
  done
}

main
