#!/usr/bin/env bash
# Claude Code PostToolUse hook: format files after Edit/Write
# Reads JSON from stdin, extracts file_path from tool_input, runs prettier.

set -eo pipefail

# Read hook payload from stdin
INPUT=$(head -c 4096)

# Extract file_path from tool_input JSON
FILE_PATH=$(printf '%s' "$INPUT" | python3 -c "
import sys, json
data = json.load(sys.stdin)
tool_input = data.get('tool_input', {})
if isinstance(tool_input, str):
    tool_input = json.loads(tool_input)
print(tool_input.get('file_path', ''))
" 2>/dev/null) || exit 0

[[ -z "$FILE_PATH" || ! -f "$FILE_PATH" ]] && exit 0

# Only format known file types
case "${FILE_PATH##*.}" in
  js|jsx|ts|tsx|mjs|cjs|json|css|scss|less|html|vue|svelte|yaml|yml|md|mdx|graphql|gql)
    ;;
  *)
    exit 0
    ;;
esac

# Find the nearest prettier by walking up from the file's directory.
find_prettier() {
  local dir
  dir=$(dirname "$FILE_PATH")
  while [[ "$dir" != "/" ]]; do
    if [[ -x "$dir/node_modules/.bin/prettier" ]]; then
      echo "$dir/node_modules/.bin/prettier"
      return
    fi
    dir=$(dirname "$dir")
  done
  command -v prettier 2>/dev/null
}

PRETTIER=$(find_prettier)
[[ -z "$PRETTIER" ]] && exit 0

# Only run if the project has a prettier config (don't impose formatting on unconfigured projects)
has_config() {
  local dir
  dir=$(dirname "$FILE_PATH")
  while [[ "$dir" != "/" ]]; do
    for cfg in .prettierrc .prettierrc.json .prettierrc.yml .prettierrc.yaml .prettierrc.js .prettierrc.cjs .prettierrc.mjs .prettierrc.toml prettier.config.js prettier.config.cjs prettier.config.mjs; do
      [[ -f "$dir/$cfg" ]] && return 0
    done
    if [[ -f "$dir/package.json" ]] && python3 -c "import json,sys; sys.exit(0 if 'prettier' in json.load(open('$dir/package.json')) else 1)" 2>/dev/null; then
      return 0
    fi
    dir=$(dirname "$dir")
  done
  return 1
}

has_config || exit 0

# Run prettier (silently, don't fail the hook if formatting fails)
"$PRETTIER" --write "$FILE_PATH" >/dev/null 2>&1 || true
